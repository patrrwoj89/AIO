    "formatter": {
      "id": "custom",
      "definition": {
        "name": "",
        "description": "{service.cached::istrue[\"⚡ \"||\"\"]}{stream.title::exists[\"🎬 {stream.title::truncate(28)}\"||\"\"]}{stream.formattedSeasons::exists[\" {stream.formattedSeasons}\"||\"\"]}{stream.formattedEpisodes::exists[\"{stream.formattedEpisodes}\"||\"\"]}{stream.year::exists[\" ({stream.year})\"||\"\"]}\n{stream.resolution::=2160p[\"📽 4K\"||\"\"]}{stream.resolution::=1440p[\" 📽 1440p\"||\"\"]}{stream.resolution::=1080p[\" 📽 1080p\"||\"\"]}{stream.resolution::=720p[\" 📽 720p\"||\"\"]}{stream.visualTags::~HDR[\" 🌟 HDR\"||\"\"]}{stream.visualTags::~DV[\" 🌟 DV\"||\"\"]}{stream.visualTags::~10bit[\" 🎨 10-bit\"||\"\"]}\n{stream.filename::~LEKTOR[\"🎤 PL (Lektor)\"||\"\"]}\n{stream.filename::~PLDUB[\"🎤 PL (Dubbing)\"||\"\"]}\n{stream.filename::~DUBBING[\"🎤 PL (Dubbing)\"||\"\"]}\n{stream.languageCodes::~PL::and::stream.filename::~PLSUB::isfalse[\"🎤 PL (Audio)\"||\"\"]}\n{stream.filename::~PLSUB[\"📜 PL (Napisy)\"||\"\"]}\n{stream.folderName::~Napisy[\"📜 PL (Napisy)\"||\"\"]}\n{stream.languageCodes::~EN::and::stream.languageCodes::~PL::isfalse[\"🎤 EN (Oryginał)\"||\"\"]}\n{stream.filename::~PLSUB::and::stream.languageCodes::~EN[\"🎤 EN (Oryginał)\"||\"\"]}\n{stream.languageCodes::~JA::and::stream.languageCodes::~PL::isfalse[\"🎤 JP (Oryginał)\"||\"\"]}\n{stream.languageCodes::~PL::isfalse::and::stream.subtitleCodes::~PL::isfalse::and::stream.filename::~PLSUB::isfalse[\"🌍 Zagraniczne (Brak PL)\"||\"\"]}\n{stream.audioTags::exists[\"🔊 {stream.audioTags::join('·')}\"||\"\"]}\n{stream.size::>0[\"💾 {stream.size::rbytes}\"||\"\"]}{stream.bitrate::exists[\" {stream.bitrate::rbitrate}\"||\"\"]}"
      }
    },
