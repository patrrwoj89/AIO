    ],
    "preferredStreamExpressions": [
      {
        "expression": "regexMatched(streams,'pl_audio')",
        "enabled": true
      },
      {
        "expression": "regexMatched(streams,'pl_sub')",
        "enabled": true
      }
    ],
    "rankedStreamExpressions": [
      {
        "expression": "regexMatched(streams,'pl_audio')",
        "score": 1600,
        "enabled": true
      },
      {
        "expression": "language(streams,'Polish')",
        "score": 1400,
        "enabled": true
      },
      {
        "expression": "regexMatched(streams,'pl_sub')",
        "score": 1000,
        "enabled": true
      },
      {
        "expression": "cached(streams)",
        "score": 900,
        "enabled": true
      }
    ],
    "regexOverrides": [
      {
        "pattern": "(?i)(PLDUB|DUBBING|LEKTOR|PL\\.LEKTOR|PL\\.DUB|POLSKI|POLISH|PL\\.AC3|PL\\.DDP|PL\\.ATMOS|audio.*pl|multi.*pl)",
        "name": "pl_audio"
      },
      {
        "pattern": "(?i)(napisy|sub.*pl|polish.*sub|\\[PL\\])",
        "name": "pl_sub"
      }
    ],
    "dynamicAddonFetching": {
      "enabled": {
        "__switch": "inputs.enableDynamicFetch",
        "cases": {
