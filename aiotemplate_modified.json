{
  "metadata": {
    "id": "aiostreams|pl-2026-03-18.18-15-11-mc073nn",
    "name": "AIOStreams|PL",
    "description": "Zoptymalizowana konfiguracja dodatku AIOStreams, maksymalizująca dostępność polskich treści dzięki zaawansowanej agregacji źródeł i autorskim filtrom regex.",
    "source": "external",
    "author": "Tomf",
    "version": "2.1.0",
    "category": "Debrid",
    "serviceRequired": true,
    "setToSaveInstallMenu": true,
	"inputs": [
      
	  
	   {
        "id": "tmdbApiKey",
        "type": "password",
        "name": "TMDB API Key (OPCJONALNE)",
        "description": "Podaj swój 'Klucz API' (API Key) aby automatycznie aktywować zaawansowane dopasowywanie tytułów (Title Matching) i lat produkcji (Year Matching). Możesz go uzyskać w sekcji [ustawienia konta TMDB](https://www.themoviedb.org/settings/api). Upewnij się, że skopiujesz 32‑znakowy API Key a nie API Read Access Token.",
        "required": false
      },
      {
        "id": "tmdbAccessToken",
        "type": "password",
        "name": "TMDB Access Token (OPCJONALNE)",
        "description": "Podaj swój 'Przeczytaj kod odczytu API' (API Read Access Token) aby automatycznie aktywować zaawansowane dopasowywanie tytułów (Title Matching) i lat produkcji (Year Matching). Możesz go uzyskać w sekcji [ustawienia konta TMDB](https://www.themoviedb.org/settings/api). Upewnij się, że skopiujesz API Read Access Token, a nie 32‑znakowy API Key.",
        "required": false
      },
      {
        "id": "tvdbApiKey",
        "type": "password",
        "name": "TVDB API Key (OPCJONALNE)",
        "description": "Podaj swój klucz API TVDB, aby także pobrać metadane z TVDB. Zarejestruj się, aby uzyskać darmowy klucz API na stronie [TVDB](https://www.thetvdb.com/api-information).",
        "required": false
      }
	  ,
	  {
        "id": "debridioApiKey",
        "type": "password",
        "name": "Debridio API Key (OPCJONALNE)",
        "description": "Podaj klucz API Debridio. Jeśli go wpiszesz, dodatek zostanie automatycznie włączony. Możesz go uzyskać na stronie [debridio.com/account](https://debridio.com/account).",
        "required": false
      }
	  ,
	  {
        "id": "includeAnime",
        "type": "boolean",
        "name": "Włącz wsparcie dla Anime",
        "description": "Aktywuje dedykowane wtyczki (np. SeaDex, AnimeTosho) ułatwiające wyszukiwanie anime.",
        "default": false
      }
	  ,
	  {
        "id": "exclude3D",
        "type": "boolean",
        "name": "Ukryj materiały 3D / VR",
        "description": "Wyklucza z wyników pliki w formatach 3D (H-OU, H-SBS), które na zwykłym ekranie wyświetlają się jako podzielony obraz.",
        "default": true
      }
	  ,
	  {
        "id": "blockCams",
        "type": "boolean",
        "name": "Ukryj materiały niskiej jakości (CAM / TS)",
        "description": "Zaznacz, aby zablokować nagrania z kina i wersje promocyjne. Odznacz, jeśli chcesz mieć do nich dostęp w przypadku najnowszych premier.",
        "default": true
      },
	  {
        "id": "hideUncached",
        "type": "boolean",
        "name": "Ukryj niezbuforowane źródła (Uncached)",
        "description": "Zaznacz, aby wyświetlać tylko materiały od razu gotowe do odtwarzania (cached). Ukrywa linki wymagające wcześniejszego pobrania przez serwis Debrid.",
        "default": true
      }
	  ,
      {
        "id": "enableDynamicFetch",
        "type": "boolean",
        "name": "Włącz dynamiczne pobieranie wyników z dodatków",
        "description": "Aktywuje dynamiczne pobieranie wyników (Dynamic Addon Fetching).Szybsze zwracanie wyników – potencjalnie kosztem ich ilości",
        "default": false
      }
    ]
  },
